{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://www.konarcard.com/:path*",
      "statusCode": 301,
      "has": [{ "type": "host", "value": "konarcard.com" }]
    },
    { "source": "/products/metal-card", "destination": "/products", "statusCode": 301 },
    { "source": "/products/metal", "destination": "/products", "statusCode": 301 },
    { "source": "/products/konartag", "destination": "/products", "statusCode": 301 },
    { "source": "/products/plastic-bundle", "destination": "/products", "statusCode": 301 },
    { "source": "/products/metal-bundle", "destination": "/products", "statusCode": 301 },
    { "source": "/products/plastic", "destination": "/products", "statusCode": 301 },
    { "source": "/products/plastic-card", "destination": "/products", "statusCode": 301 },
    { "source": "/faqs", "destination": "/faq", "statusCode": 301 },
    { "source": "/claimyourlink", "destination": "/register", "statusCode": 301 },
    { "source": "/how-it-works", "destination": "/", "statusCode": 301 },
    { "source": "/share", "destination": "/", "statusCode": 301 },
    { "source": "/u/-", "destination": "/examples", "statusCode": 301 },
    { "source": "/u/z", "destination": "/examples", "statusCode": 301 }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/u/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}